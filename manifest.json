{
  "manifest_version": 3,
  "name": "Jane Street 自动填表终极版",
  "version": "1.2",
  "permissions": ["activeTab", "scripting"],
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": [
        "*://*.janestreet.com/*",
        "*://*.greenhouse.io/*",
        "*://*.myworkdayjobs.com/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}
